# Gold Trend Desk example environment
# Copy this file to .env or configure these variables in your hosting platform.

# Web server
PORT=4173

# Product identity
PRODUCT_ID=gold-trend-desk
APP_VERSION=1.0.1

# License center integration
# Leave LICENSE_REQUIRED=false for local demos.
# Set LICENSE_REQUIRED=true only after you have a compatible license center.
LICENSE_REQUIRED=false
LICENSE_SERVER_URL=https://license-center.example.com
LICENSE_PUBLIC_KEY_PATH=/absolute/path/to/license-public.pem

# Optional legacy local access code for development only.
# Do not use this as commercial licensing.
AUTH_CODE=

# Cloud update controls
UPDATE_APPLY_ENABLED=false
UPDATE_DOWNLOAD_MAX_BYTES=536870912
